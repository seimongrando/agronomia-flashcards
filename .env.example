# ═══════════════════════════════════════════════════════════════════════════════
# .env.example — Reference for all environment variables
#
# For local development copy .env.local.example instead:
#   cp .env.local.example .env.local
#
# This file documents every supported variable with its default value.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development           # development | production

# ── Database ──────────────────────────────────────────────────────────────────
# Full connection string; sslmode=require in production (Render sets this).
DATABASE_URL=postgres://user:password@localhost:5432/webapp?sslmode=disable

# (Used by docker-compose only — not read by the Go server directly)
POSTGRES_USER=webapp
POSTGRES_PASSWORD=webapp_dev
POSTGRES_DB=webapp

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# ── JWT / Session ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-at-least-32-random-chars
JWT_EXPIRY=24h

# ── RBAC / Admin bootstrap ────────────────────────────────────────────────────
# Comma-separated emails auto-promoted to admin on first login.
ADMIN_EMAILS=admin@example.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Empty = reject all cross-origin.
ALLOWED_ORIGINS=http://localhost:8080

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                    # debug | info | warn | error

# ── Rate limiting ─────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT_RPS=0.5           # requests/s for /auth/* routes
AUTH_RATE_LIMIT_BURST=5
API_RATE_LIMIT_RPS=2              # requests/s for /api/* routes
API_RATE_LIMIT_BURST=20

# ── HTTP timeouts & body size ─────────────────────────────────────────────────
READ_TIMEOUT=5s
WRITE_TIMEOUT=10s
IDLE_TIMEOUT=120s
MAX_BODY_SIZE=2097152             # 2 MB
