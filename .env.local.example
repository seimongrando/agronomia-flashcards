# ═══════════════════════════════════════════════════════════════════════════════
# .env.local.example — Local development environment
#
# Copy this file:  cp .env.local.example .env.local
# Then fill in:    GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, ADMIN_EMAILS
#
# ⚠  .env.local is excluded from git (see .gitignore).
#    Never commit real secrets to the repository.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Postgres (matches docker-compose.yml defaults) ────────────────────────────
POSTGRES_USER=webapp
POSTGRES_PASSWORD=webapp_dev
POSTGRES_DB=webapp
DATABASE_URL=postgres://webapp:webapp_dev@localhost:5432/webapp?sslmode=disable

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create OAuth 2.0 credentials at:
#   https://console.cloud.google.com/apis/credentials
#
# Authorized JavaScript origins:  http://localhost:8080
# Authorized redirect URI:        http://localhost:8080/auth/google/callback
#
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# ── JWT / Session ─────────────────────────────────────────────────────────────
# Any string ≥ 32 characters works locally.
# Generate a strong one: openssl rand -hex 32
JWT_SECRET=local-dev-secret-replace-with-32-or-more-random-characters
JWT_EXPIRY=24h

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# Comma-separated list of Google account emails that are automatically
# promoted to the "admin" role on their first login.
# Example: ADMIN_EMAILS=alice@gmail.com,bob@example.com
ADMIN_EMAILS=seuemail@gmail.com

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:8080
LOG_LEVEL=debug

# ── Cookies ───────────────────────────────────────────────────────────────────
# COOKIE_SECURE=false is required for local HTTP (non-HTTPS) development.
# In production, omit this line (defaults to true when ENVIRONMENT=production).
COOKIE_SECURE=false

# ── Rate limits (relaxed for local dev) ──────────────────────────────────────
AUTH_RATE_LIMIT_RPS=10
AUTH_RATE_LIMIT_BURST=20
API_RATE_LIMIT_RPS=50
API_RATE_LIMIT_BURST=100

# ── Timeouts & body size ──────────────────────────────────────────────────────
READ_TIMEOUT=10s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=120s
MAX_BODY_SIZE=2097152
